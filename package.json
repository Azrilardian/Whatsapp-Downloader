{
  "name": "whatsapp-downloader",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "shared",
    "worker",
    "dashboard"
  ],
  "scripts": {
    "worker": "npm run --workspace worker start",
    "worker:once": "npm run --workspace worker start:once",
    "dashboard": "npm run --workspace dashboard dev",
    "typecheck": "npm run --workspaces --if-present typecheck",
    "supervise": "pm2 start ecosystem.config.cjs",
    "supervise:stop": "pm2 stop ecosystem.config.cjs",
    "supervise:logs": "pm2 logs wadl-worker"
  },
  "devDependencies": {
    "pm2": "^5.4.0"
  }
}
